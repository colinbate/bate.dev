---
import { SITE_TITLE } from "$data/constants";
import type { ImageMetadata } from "astro";
import defaultImage from "$asset/bate-dev-social.jpg";
import gardenImage from "$asset/bate-dev-garden.jpg";
interface Props {
    title: string;
    description: string;
    ogtitle?: string;
    ogdescription?: string;
    publishTime?: string;
    updateTime?: string;
    img?: ImageMetadata;
    alt?: string;
    ogImageUrl?: string;
}
const {
    title,
    ogtitle,
    description,
    ogdescription,
    publishTime,
    updateTime,
    img,
    alt,
    ogImageUrl,
} = Astro.props;

const isGarden = Astro.url.pathname.startsWith("/garden/");
const image = img ?? (isGarden ? gardenImage : defaultImage);
const altext =
    alt ??
    (isGarden
        ? `Colin Bate's Digital Garden, written over a fantasy garden image`
        : `<bate.dev> The portfolio and developer blog of Colin Bate`);

const baseUrl = Astro.site ?? Astro.url;
const defaultCanonicalUrl = new URL(
    Astro.url.pathname + Astro.url.search,
    baseUrl,
);
const canonicalHref = defaultCanonicalUrl.href;
const imgUrl = ogImageUrl ?? new URL(image.src, baseUrl).href;
const imageType = ogImageUrl ? "png" : image.format;
const imageWidth = ogImageUrl ? "1200" : image.width.toString();
const imageHeight = ogImageUrl ? "630" : image.height.toString();
const metaTitle = ogtitle ?? (title || SITE_TITLE);
const metaDescription = ogdescription ?? description;
---

<title>{`${SITE_TITLE} | ${title}`}</title>
<link rel="canonical" href={canonicalHref} />
<meta property="description" content={description} />
<meta property="og:title" content={metaTitle} />
<meta property="og:type" content={publishTime ? "article" : "website"} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:image" content={imgUrl} />
<meta property="og:image:type" content={`image/${imageType}`} />
<meta property="og:image:width" content={imageWidth} />
<meta property="og:image:height" content={imageHeight} />
<meta property="og:image:alt" content={altext} />
<meta property="og:description" content={metaDescription} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={metaTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={imgUrl} />
{
    publishTime ? (
        <meta property="article:published_time" content={publishTime} />
    ) : null
}
{
    updateTime ? (
        <meta property="article:modified_time" content={updateTime} />
    ) : null
}
